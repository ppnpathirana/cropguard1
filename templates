</div>

<!-- ══ EVENT LOG ══ -->
<div class="panel" id="tab-log">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--s3)">
    <span style="font-weight:800;font-size:var(--tb)">Event Log</span>
    <button class="btn btn-gh btn-sm" onclick="document.getElementById('logBox').innerHTML=''">Clear</button>
  </div>
  <div class="log-box" id="logBox">
    <div class="log-ln">Waiting for events…</div>
  </div>
</div>

</div><!-- /.body -->
</div><!-- /.app -->

<!-- ══ TREATMENT MODAL ══ -->
<div class="modal-bg" id="fertModal">
  <div class="modal">
    <div class="modal-hdr">
      <h2 id="fertTitle">Treatment Analysis</h2>
      <button class="modal-close" onclick="closeFert()">✕</button>
    </div>
    <div class="modal-body" id="fertBody">
      <div style="text-align:center;padding:2rem">
        <div class="spinner" style="width:32px;height:32px;border-width:3px;margin:0 auto var(--s3)"></div>
        <div style="color:var(--txm);font-size:var(--tx)">Loading…</div>
      </div>
    </div>
  </div>
</div>

<script>
// ══ Treatments data (mirrored from treatments.py) ════════════════
const TX = {
  "Apple Scab Leaf":{severity:"medium",cause:"Fungal - Venturia inaequalis. Spreads in wet cool conditions.",chemical:[{name:"Captan",dose:"2g/L",interval:"Every 7-10 days"},{name:"Myclobutanil",dose:"1ml/L",interval:"At early signs"}],organic:[{name:"Sulfur spray",dose:"3g/L",interval:"Weekly"},{name:"Neem oil",dose:"5ml/L",interval:"Weekly"}],prevention:"Prune infected branches. Avoid overhead watering.",urgency_hours:72},
  "Apple rust leaf":{severity:"high",cause:"Fungal - Gymnosporangium.",chemical:[{name:"Propiconazole",dose:"1ml/L",interval:"Before symptoms"}],organic:[{name:"Copper fungicide",dose:"2g/L",interval:"Early spring"}],prevention:"Remove nearby wild juniper bushes.",urgency_hours:48},
  "Bell_pepper leaf spot":{severity:"high",cause:"Bacterial - Xanthomonas campestris.",chemical:[{name:"Copper hydroxide",dose:"2.5g/L",interval:"Every 7 days"}],organic:[{name:"Copper soap",dose:"Spray until dripping",interval:"Every 7-10 days"}],prevention:"Use drip irrigation. Rotate crops.",urgency_hours:24},
  "Corn Gray leaf spot":{severity:"high",cause:"Fungal - Cercospora zeae-maydis.",chemical:[{name:"Azoxystrobin",dose:"1ml/L",interval:"At first sign"}],organic:[{name:"Neem oil",dose:"5ml/L",interval:"Weekly"}],prevention:"Plant resistant hybrids. Rotate with non-host crops.",urgency_hours:48},
  "Corn leaf blight":{severity:"high",cause:"Fungal - Exserohilum turcicum.",chemical:[{name:"Mancozeb",dose:"2g/L",interval:"Every 7-10 days"}],organic:[{name:"Copper fungicide",dose:"2g/L",interval:"Weekly"}],prevention:"Use resistant varieties. Remove crop debris.",urgency_hours:48},
  "Potato leaf early blight":{severity:"high",cause:"Fungal - Alternaria solani.",chemical:[{name:"Chlorothalonil",dose:"2ml/L",interval:"Every 7 days"}],organic:[{name:"Copper fungicide",dose:"2g/L",interval:"Weekly"}],prevention:"Avoid overhead irrigation. Rotate crops.",urgency_hours:48},
  "Potato leaf late blight":{severity:"critical",cause:"Oomycete - Phytophthora infestans. Rapidly fatal.",chemical:[{name:"Metalaxyl-M",dose:"2.5g/L",interval:"Every 5-7 days"}],organic:[{name:"Copper hydroxide",dose:"2.5g/L",interval:"Every 5 days"}],prevention:"Plant certified disease-free seed.",urgency_hours:12},
  "Tomato Early blight leaf":{severity:"high",cause:"Fungal - Alternaria solani.",chemical:[{name:"Chlorothalonil",dose:"2ml/L",interval:"Every 7 days"}],organic:[{name:"Copper fungicide",dose:"2g/L",interval:"Weekly"}],prevention:"Stake plants for airflow.",urgency_hours:48},
  "Tomato Septoria leaf spot":{severity:"medium",cause:"Fungal - Septoria lycopersici.",chemical:[{name:"Chlorothalonil",dose:"2ml/L",interval:"Every 7-10 days"}],organic:[{name:"Copper soap",dose:"Spray until wet",interval:"Weekly"}],prevention:"Remove bottom leaves.",urgency_hours:72},
  "Tomato leaf late blight":{severity:"critical",cause:"Oomycete - Phytophthora infestans.",chemical:[{name:"Metalaxyl-M",dose:"2.5g/L",interval:"Every 5-7 days"}],organic:[{name:"Copper hydroxide",dose:"2.5g/L",interval:"Every 5 days"}],prevention:"Remove all infected material immediately.",urgency_hours:12},
  "Tomato leaf mold":{severity:"medium",cause:"Fungal - Fulvia fulva.",chemical:[{name:"Chlorothalonil",dose:"2ml/L",interval:"Every 7-10 days"}],organic:[{name:"Copper soap",dose:"5ml/L",interval:"Weekly"}],prevention:"Improve ventilation. Keep humidity below 85%.",urgency_hours:72},
  "Tomato leaf mosaic virus":{severity:"high",cause:"Viral - Tomato Mosaic Virus.",chemical:[{name:"No cure – remove infected plants",dose:"--",interval:"Immediately"}],organic:[{name:"Disinfect tools with 10% bleach",dose:"--",interval:"Between plants"}],prevention:"Use virus-free seed. Wash hands.",urgency_hours:24},
  "Tomato leaf yellow virus":{severity:"critical",cause:"Viral - TYLCV spread by whiteflies.",chemical:[{name:"Imidacloprid",dose:"0.5ml/L",interval:"Every 7 days"}],organic:[{name:"Yellow sticky traps",dose:"1 per 5m²",interval:"Replace weekly"},{name:"Neem oil",dose:"5ml/L",interval:"Every 5 days"}],prevention:"Use reflective mulch.",urgency_hours:24},
  "Tomato spider mite bug":{severity:"medium",cause:"Pest - Tetranychus urticae.",chemical:[{name:"Abamectin",dose:"1ml/L",interval:"Every 7 days"}],organic:[{name:"Neem oil",dose:"5ml/L",interval:"Every 5 days"}],prevention:"Maintain adequate soil moisture.",urgency_hours:48},
  "Grape leaf black rot":{severity:"high",cause:"Fungal - Guignardia bidwellii.",chemical:[{name:"Myclobutanil",dose:"1ml/L",interval:"Every 10-14 days"}],organic:[{name:"Copper fungicide",dose:"2g/L",interval:"Weekly"}],prevention:"Remove mummified fruit. Prune for airflow.",urgency_hours:48},
  "Squash Powdery mildew leaf":{severity:"medium",cause:"Fungal - Erysiphe cichoracearum.",chemical:[{name:"Myclobutanil",dose:"1ml/L",interval:"Every 10-14 days"}],organic:[{name:"Neem oil",dose:"5ml/L",interval:"Every 5 days"}],prevention:"Plant resistant varieties.",urgency_hours:72},
};

// ══ Socket.IO ════════════════════════════════════════════════════
const socket = io({
  transports: ['polling','websocket'],
  upgrade: true,
  reconnection: true,
  reconnectionAttempts: Infinity,
  reconnectionDelay: 1000,
  timeout: 20000,
});

let mode = 'manual', lastPos = null, scanCount = 0;

socket.on('connect', () => {
  dot('connecting');
  log('Socket connected id=' + socket.id, 'info');
});
socket.on('disconnect', () => {
  dot('offline');
  log('Disconnected – reconnecting…', 'error');
});
socket.on('connect_error', e => log('Connect error: ' + e.message, 'error'));

socket.on('connected', d => {
  dot('online');
  setText('sTxt', 'Online');
  log('🚀 ' + d.status + ' | port: ' + (d.port||'N/A'), 'success');
  loadHistory();
});

socket.on('esp32_status', d => {
  const b = document.getElementById('b-esp');
  if (d.online) { b.textContent='ESP32: online'; b.className='badge b-ok'; }
  else          { b.textContent='ESP32: searching'; b.className='badge b-wa'; }
  log((d.online?'✅':'⚠️') + ' ESP32 ' + (d.online?'on '+d.port:'disconnected'), d.online?'success':'warn');
});

socket.on('sensor_update', d => {
  kpi('temp', d.temperature, v => v>35?'warn':v<10?'warn':'good');
  kpi('hum',  d.humidity,    v => v>85?'warn':'good');
  kpi('soil', d.soilpercent, v => v<20?'err':v>80?'warn':'good');
  kpi('lux',  d.lux,         v => v<200?'warn':v>80000?'warn':'good');
  kpi('batt', d.batterypercent, v => v<20?'err':v<40?'warn':'good');
  kpi('dist', d.distancefront,  v => v<25?'err':'good');
  kpi('sats', d.gpssats,        v => v>3?'good':'warn');
  // Light intensity — Soil tab card
  const luxV = parseFloat(d.lux) || 0;
  setText('luxVal', luxV >= 1000 ? (luxV/1000).toFixed(1)+'k' : luxV.toFixed(1));
  const luxLabel = luxV < 10    ? '🌑 Night'    :
                   luxV < 200   ? '🌘 Very dim'  :
                   luxV < 1000  ? '💡 Indoor'    :
                   luxV < 10000 ? '⛅ Overcast'  :
                   luxV < 40000 ? '🌤 Bright'    : '☀️ Full sun';
  setText('luxBadge', luxLabel);
  const lb = document.getElementById('luxBadge');
  if (lb) lb.className = 'badge ' + (luxV < 200 ? 'b-wa' : luxV > 80000 ? 'b-wa' : 'b-ok');
  // sqrt-scale bar so low-lux values are still visible (0–100 000 lux → 0–100%)
  const luxPct = Math.min(100, Math.sqrt(luxV / 1000) * 31.623);
  const lf = document.getElementById('luxFill');
  if (lf) lf.style.width = luxPct.toFixed(1) + '%';
  // Soil tab
  const sp = parseFloat(d.soilpercent)||0;
  setText('soilPct', sp.toFixed(1));
  document.getElementById('soilFill').style.width = Math.min(sp,100)+'%';
  setText('soilSt', sp<20?'🔴 Very dry':sp<40?'🟡 Dry':sp<70?'🟢 Optimal':'🔵 Wet');
  // GPS
  if (d.gpslat && d.gpslng) {
    setText('gLat', parseFloat(d.gpslat).toFixed(6));
    setText('gLng', parseFloat(d.gpslng).toFixed(6));
    setText('gSats', d.gpssats||0);
    updateMap(d.gpslat, d.gpslng);
  }
  // Status badges
  const sats = parseInt(d.gpssats)||0;
  setBadge('b-gps', sats>3 ? ['GPS: fix','b-ok'] : ['GPS: no fix','b-wa']);
  if (d.motor_state) setBadge('b-mot', ['Motor: '+(d.motor_state.direction||'stop'), 'b-bl']);
  if (d.brain_state) {
    mode = d.brain_state.mode||'manual';
    const mp = document.getElementById('modePill');
    mp.textContent = mode.toUpperCase();
    mp.className   = 'mode-pill' + (mode==='auto'?' auto':'');
    scanCount = d.brain_state.scan_count||scanCount;
    setText('b-scn', 'Scans: '+scanCount);
  }
  if (d.esp32online !== undefined) {
    setBadge('b-esp', [d.esp32online?'ESP32: online':'ESP32: offline', d.esp32online?'b-ok':'b-wa']);
  }
});

// ══ Drive ════════════════════════════════════════════════════════
const JOY={forward:{x:0,y:1},backward:{x:0,y:-1},left:{x:-1,y:0},right:{x:1,y:0},stop:{x:0,y:0}};
function drive(dir){
  socket.emit('joystick', JOY[dir]||JOY.stop);
  document.querySelectorAll('.dpb').forEach(b=>b.classList.remove('on'));
  const ids={forward:'dpFwd',backward:'dpBk',left:'dpL',right:'dpR'};
  if(ids[dir]) document.getElementById(ids[dir]).classList.add('on');
}
function onSpeed(v){ setText('spdVal',v); socket.emit('set_speed',{speed:parseInt(v)}); }

// ══ Arm ══════════════════════════════════════════════════════════
let _armT = null;
function armSlide(){
  ['base','shoulder','elbow','wrist'].forEach(j=>{
    setText('sv-'+j, document.getElementById('sl-'+j).value);
  });
  clearTimeout(_armT);
  _armT = setTimeout(()=>{
    socket.emit('arm_position',{
      base:     +document.getElementById('sl-base').value,
      shoulder: +document.getElementById('sl-shoulder').value,
      elbow:    +document.getElementById('sl-elbow').value,
      wrist:    +document.getElementById('sl-wrist').value,
    });
  }, 80);
}
const PRESETS = {
  home:     {base:1500,shoulder:1200,elbow:1800,wrist:1500},
  scan:     {base:1500,shoulder:1600,elbow:1400,wrist:1500},
  panleft:  {base:800, shoulder:1200,elbow:1800,wrist:1500},
  panright: {base:2200,shoulder:1200,elbow:1800,wrist:1500},
};
function armPreset(n){
  const p=PRESETS[n]; if(!p) return;
  Object.entries(p).forEach(([k,v])=>{
    document.getElementById('sl-'+k).value=v;
    setText('sv-'+k,v);
  });
  socket.emit('arm_position',p);
}

// ══ Pan/Tilt ═════════════════════════════════════════════════════
let _ptT=null, _ptLast={pan:90,tilt:90};
function onPT(){
  const pan=+document.getElementById('sl-pan').value;
  const tilt=+document.getElementById('sl-tilt').value;
  setText('sv-pan',pan); setText('sv-tilt',tilt);
  clearTimeout(_ptT);
  _ptT=setTimeout(()=>{
    socket.emit('pantilt',{pan,tilt});
    _ptLast={pan,tilt};
  },80);
}
function snapPT(pan,tilt){
  document.getElementById('sl-pan').value=pan;
  document.getElementById('sl-tilt').value=tilt;
  setText('sv-pan',pan); setText('sv-tilt',tilt);
  socket.emit('pantilt',{pan,tilt});
  _ptLast={pan,tilt};
}

// ══ Probe ════════════════════════════════════════════════════════
function probeNow(){ socket.emit('probe_now',{}); log('🔽 Probing soil…','info'); }
socket.on('soil_reading', d=>{
  const m=parseFloat(d.moisture||0);
  setText('soilPct',m.toFixed(1));
  document.getElementById('soilFill').style.width=Math.min(m,100)+'%';
  log('💧 Soil: '+m.toFixed(1)+'%','success');
});

// ══ GPS map ══════════════════════════════════════════════════════
function updateMap(lat,lng){
  const p=parseFloat(lat).toFixed(4)+','+parseFloat(lng).toFixed(4);
  if(p===lastPos) return;
  lastPos=p;
  document.getElementById('mapFr').src=
    'https://maps.google.com/maps?q='+lat+','+lng+'&z=17&output=embed';
}

// ══ Mode ═════════════════════════════════════════════════════════
function toggleMode(){
  mode = mode==='manual'?'auto':'manual';
  socket.emit('set_mode',{mode});
  const mp=document.getElementById('modePill');
  mp.textContent=mode.toUpperCase();
  mp.className='mode-pill'+(mode==='auto'?' auto':'');
}

// ══ Patrol ═══════════════════════════════════════════════════════
const CROPS=['Rice','Wheat','Corn','Tomato','Potato','Pepper','Apple','Grape','Strawberry','Peach'];
(function buildCrops(){
  const g=document.getElementById('cropGrid');
  g.innerHTML=CROPS.map(c=>
    `<label class="crop-chip"><input type="checkbox" value="${c}"><span>${c}</span></label>`
  ).join('');
})();

function startPatrol(){
  const crops=[...document.querySelectorAll('#cropGrid input:checked')].map(c=>c.value);
  if(!crops.length){ setText('patSt','⚠️ Select at least one crop'); return; }
  socket.emit('start_patrol',{crops});
  setText('patSt','🚜 Patrolling: '+crops.join(', '));
  log('🚜 Patrol started: '+crops.join(', '),'success');
}
function stopPatrol(){ socket.emit('stop_patrol',{}); setText('patSt','Patrol stopped.'); }
function emergencyStop(){
  socket.emit('emergency_stop',{});
  log('⛔ EMERGENCY STOP','error');
  showAlert('Emergency stop activated!');
}
socket.on('patrol_status', d=>{
  setText('patSt', d.running?'🚜 Patrol running…':'Patrol stopped.');
  const b=document.getElementById('btnStart');
  if(b) b.disabled=!!d.running;
});
socket.on('emergency_stopped', ()=>{
  setText('patSt','Emergency stopped.');
  log('⛔ Emergency stopped','error');
});
socket.on('robot_action', d=>log('🤖 '+d.action,'info'));
socket.on('disease_detected', d=>{
  addDetCard(d, 'patList');
  renderLastDet(d);
  showAlert('Disease: '+d.disease);
  log('🦠 '+d.disease+' '+parseFloat(d.confidence||0).toFixed(1)+'%','warn');
  scanCount++;
  setText('b-scn','Scans: '+scanCount);
});
socket.on('scan_result', d=>{
  if(!d.disease||d.disease.includes('No disease')) log('✅ Scan: no disease','success');
});
socket.on('patrol_ended', d=>log('✅ Patrol ended. '+d.summary,'success'));

function addDetCard(d, listId){
  const list=document.getElementById(listId);
  const empty=list.querySelector('[style*="txf"]');
  if(empty) empty.remove();
  const sev=(d.severity||'low').toLowerCase();
  const bc=sev==='critical'||sev==='high'?'b-er':sev==='medium'?'b-wa':'b-ok';
  const el=document.createElement('div');
  el.className='det-card sev-'+sev;
  el.innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--s2)">
      <strong class="clickable" onclick='openFert(${JSON.stringify(d).replace(/'/g,"&#39;")})'>${d.disease||'Unknown'}</strong>
      <span class="badge ${bc}">${sev}</span>
    </div>
    <div style="font-size:var(--tx);color:var(--txm);font-family:var(--mono)">
      Conf: ${parseFloat(d.confidence||0).toFixed(1)}% &nbsp;|&nbsp;
      Soil: ${parseFloat(d.soil_moisture||0).toFixed(1)}% &nbsp;|&nbsp;
      Temp: ${parseFloat(d.temperature||0).toFixed(1)}°C
    </div>
    <div style="margin-top:var(--s2);font-size:var(--tx);color:var(--pr)">↑ Click disease name for treatment plan</div>`;
  list.prepend(el);
}

// ══ History ═══════════════════════════════════════════════════════
function loadHistory(){ socket.emit('get_history',{}); }
socket.on('history_data', d=>{
  const tb=document.getElementById('histBody');
  if(!d.detections||!d.detections.length){
    tb.innerHTML='<tr><td colspan="8" style="text-align:center;color:var(--txf);padding:2rem">No records</td></tr>';
    return;
  }
  tb.innerHTML=d.detections.map(r=>{
    const sev=(r.severity||'low').toLowerCase();
    const bc=sev==='critical'||sev==='high'?'b-er':sev==='medium'?'b-wa':'b-ok';
    const ts=(r.timestamp||'').slice(0,19).replace('T',' ');
    const det=JSON.stringify(r).replace(/'/g,"&#39;");
    return `<tr>
      <td>${ts.slice(11)}</td>
      <td><span class="clickable" onclick='openFert(${det})'>${r.disease||'-'}</span></td>
      <td>${parseFloat(r.confidence||0).toFixed(1)}%</td>
      <td><span class="badge ${bc}">${r.severity||'-'}</span></td>
      <td>${r.crop||'-'}</td>
      <td>${parseFloat(r.soil_moisture||0).toFixed(1)}%</td>
      <td>${parseFloat(r.temperature||0).toFixed(1)}°C</td>
      <td style="font-size:10px">${parseFloat(r.gpslat||0).toFixed(4)},${parseFloat(r.gpslng||0).toFixed(4)}</td>
    </tr>`;
  }).join('');
});
function clearDB(){
  if(!confirm('Clear all detection history?')) return;
  socket.emit('clear_database',{});
  log('🗑 Database cleared','warn');
}

// ══ Treatment modal ═══════════════════════════════════════════════
let _fertData=null;
function openFert(d){
  _fertData=d;
  document.getElementById('fertTitle').textContent=(d.disease||'Unknown')+' — Treatment Analysis';
  document.getElementById('fertModal').classList.add('open');
  renderFert(d);
  socket.emit('get_fertilizer',{id:Date.now(),disease:d.disease,crop:d.crop});
}
function closeFert(){
  document.getElementById('fertModal').classList.remove('open');
  _fertData=null;
}
document.getElementById('fertModal').addEventListener('click',e=>{if(e.target===e.currentTarget)closeFert();});
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeFert();});

function renderFert(d){
  const tx=TX[d.disease]||null;
  const sev=tx?tx.severity:(d.severity||'unknown');
  const sevColor=sev==='critical'?'var(--er)':sev==='high'?'var(--wa)':sev==='medium'?'var(--bl)':'var(--pr)';
  let h='';
  if(tx&&tx.urgency_hours){
    h+=`<div class="urg-box"><div class="spinner"></div><strong>Act within ${tx.urgency_hours} hours</strong> — Severity: <span style="color:${sevColor};font-weight:700;text-transform:uppercase">${sev}</span></div>`;
  }
  if(tx&&tx.cause){
    h+=`<div class="cause-box"><strong>Cause:</strong> ${tx.cause}</div>`;
  }
  h+=`<div><div class="sec-title">Field Conditions at Detection</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--s2)">`;
  [['Soil',parseFloat(d.soil_moisture||0).toFixed(1)+'%'],
   ['Temp',parseFloat(d.temperature||0).toFixed(1)+'°C'],
   ['Humidity',parseFloat(d.humidity||0).toFixed(1)+'%'],
   ['Confidence',parseFloat(d.confidence||0).toFixed(1)+'%'],
   ['GPS',parseFloat(d.gpslat||0).toFixed(4)+',<br>'+parseFloat(d.gpslng||0).toFixed(4)],
   ['Zone',d.zone||'--'],
  ].forEach(([label,val])=>{
    h+=`<div style="background:var(--sf2);border:1px solid var(--bd);border-radius:var(--r);padding:var(--s2) var(--s3)">
      <div style="font-size:10px;color:var(--txm);text-transform:uppercase;letter-spacing:.06em">${label}</div>
      <div style="font-weight:700;font-size:var(--ts);font-family:var(--mono)">${val}</div></div>`;
  });
  h+='</div></div>';
  if(tx&&tx.chemical&&tx.chemical.length){
    h+='<div><div class="sec-title" style="color:var(--er)">Chemical Treatments</div>';
    tx.chemical.forEach(c=>{
      h+=`<div class="fert-item"><div class="name">${c.name}</div>
        <div class="meta"><span class="fert-chip">Dose: ${c.dose}</span><span class="fert-chip">${c.interval}</span></div></div>`;
    });
    h+='</div>';
  }
  if(tx&&tx.organic&&tx.organic.length){
    h+='<div><div class="sec-title" style="color:var(--gr)">Organic / Biological</div>';
    tx.organic.forEach(o=>{
      h+=`<div class="fert-item"><div class="name">${o.name}</div>
        <div class="meta"><span class="fert-chip">Dose: ${o.dose}</span><span class="fert-chip">${o.interval}</span></div></div>`;
    });
    h+='</div>';
  }
  if(tx&&tx.prevention){
    h+=`<div class="prev-box"><strong>Prevention:</strong> ${tx.prevention}</div>`;
  }
  h+=`<div><div class="sec-title" style="color:var(--pr)">AI Fertilizer &amp; Recovery Plan</div>
    <div id="aiPlanBox" class="ai-box">
      <div style="display:flex;align-items:center;gap:var(--s2)">
        <div class="spinner"></div>
        <span style="color:var(--txm)">Analysing soil data and generating personalised fertilizer plan…</span>
      </div>
    </div></div>`;
  if(d.ai_analysis){
    h=h.replace(/<div style="display:flex.*?<\/div>\s*<\/div>/s, d.ai_analysis);
  }
  document.getElementById('fertBody').innerHTML=h;
}

socket.on('fertilizer_ready', d=>{
  const box=document.getElementById('aiPlanBox');
  if(box) box.textContent=d.plan||'No plan generated.';
});

// ══ Last detection banner ═════════════════════════════════════════
function renderLastDet(d){
  const sev=(d.severity||'low').toLowerCase();
  const bc=sev==='critical'||sev==='high'?'b-er':sev==='medium'?'b-wa':'b-ok';
  const det=JSON.stringify(d).replace(/'/g,"&#39;");
  document.getElementById('lastDetBox').innerHTML=`
    <div style="display:flex;align-items:center;gap:var(--s2);flex-wrap:wrap">
      <span class="clickable" onclick='openFert(${det})'>${d.disease||'Unknown'}</span>
      <span class="badge ${bc}">${sev}</span>
      <span style="color:var(--txm);font-family:var(--mono)">${parseFloat(d.confidence||0).toFixed(1)}% confidence</span>
      <span style="font-size:var(--tx);color:var(--pr)">↑ Click for treatment</span>
    </div>`;
}

// ══ Alert ════════════════════════════════════════════════════════
function showAlert(msg){
  setText('alertTxt',msg);
  const b=document.getElementById('alert-bar');
  b.classList.add('show');
  setTimeout(()=>b.classList.remove('show'),6000);
}

// ══ Tabs ══════════════════════════════════════════════════════════
document.querySelectorAll('.tab').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    const panel=document.getElementById('tab-'+btn.dataset.tab);
    if(panel) panel.classList.add('active');
    if(btn.dataset.tab==='history') loadHistory();
  });
});

// ══ Theme ════════════════════════════════════════════════════════
(function(){
  const html=document.documentElement;
  const btn=document.getElementById('themeBtn');
  let dark=true;
  const MOON='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
  const SUN='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>';
  btn.innerHTML=MOON;
  btn.addEventListener('click',()=>{
    dark=!dark;
    html.setAttribute('data-theme',dark?'dark':'light');
    btn.innerHTML=dark?MOON:SUN;
  });
})();

// ══ Helpers ══════════════════════════════════════════════════════
function setText(id,v){ const e=document.getElementById(id); if(e) e.textContent=v; }
function dot(state){
  const d=document.getElementById('sDot');
  d.className='status-dot'+( state==='online'?' online':state==='connecting'?' connecting':'' );
  if(state!=='online') setText('sTxt', state==='connecting'?'Connecting…':'Offline');
}
function kpi(id,val,fn){
  const el=document.getElementById('v-'+id);
  const card=document.getElementById('kpi-'+id);
  if(!el) return;
  const n=parseFloat(val);
  el.textContent=isNaN(n)?'--':n.toFixed(n>=100?0:1);
  if(fn&&card) card.className='kpi '+(isNaN(n)?'':fn(n));
}
function setBadge(id,[text,cls]){ const e=document.getElementById(id); if(e){e.textContent=text;e.className='badge '+cls;} }
function log(msg,level=''){
  const box=document.getElementById('logBox');
  if(box.children.length===1&&box.firstChild.textContent==='Waiting for events…') box.innerHTML='';
  const d=document.createElement('div');
  d.className='log-ln'+(level?' '+level:'');
  d.textContent=new Date().toLocaleTimeString()+' '+msg;
  box.prepend(d);
  while(box.children.length>300) box.removeChild(box.lastChild);
}

log('CropGuard Dashboard ready','success');

</div>

<!-- ══ PATROL ══ -->
<div class="panel" id="tab-patrol">
  <div class="card">
    <div class="card-title">Select Crops</div>
    <div class="crop-grid" id="cropGrid"></div>
  </div>
  <div class="card">
    <div class="card-title">Patrol Control</div>

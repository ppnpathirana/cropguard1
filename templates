      <button class="btn btn-er" onclick="emergencyStop()">⛔ Emergency Stop</button>
    </div>
    <div id="patSt" style="margin-top:var(--s3);font-size:var(--ts);color:var(--txm);font-weight:500">Patrol stopped.</div>

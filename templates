</div>

<!-- ══ DETECTIONS ══ -->
<div class="panel" id="tab-history">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--s3)">
    <span style="font-weight:800;font-size:var(--tb)">Detection History</span>
    <div style="display:flex;gap:var(--s2)">
      <button class="btn btn-gh btn-sm" onclick="loadHistory()">↻ Refresh</button>
